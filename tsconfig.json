{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,

    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,

    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,

    "noEmit": true
  },

  "include": [
    "src"
  ]
}